  </div><br />

  <div class="circular-progress react">
    <span class="value">React</span>
  </div><br />

  <div class="circular-progress bootstrap">
    <span class="value">Bootstrap</span>
  </div><br />
  </div>

  <div class="stats">
  <div class="circular-progress cpp">
    <span class="value">.NetAsp</span>
  </div><br />

  
  </div>

  </div>


</aside>

    <div class="hmabout"  style="font-family: var(--bs-body-font-family); font-size:16px;">
       
         @RenderSection("hmabout", required:false)
    </div>

   
    
   <iframe src="https://www.juicer.io/api/feeds/sarang-masal-4377a9273/iframe" frameborder="0" width="1000" height="1000" class="linkframe" ></iframe>
   <br />
   <br />
   <br />
   <br />
   <br />
    
    <footer class="border-top footer text-muted" style="background-color:#f8f9fa; ">
         <div class="container" >
            <div class="social-icons">
                <a href="https://www.linkedin.com/in/sarang-masal-4377a9273/" target="_blank">
            <i class="fab fa-linkedin"></i>
                </a>
                <a href="https://discord.com" target="_blank">
            <i class="fab fa-discord"></i>
                </a>
                <a href="https://twitter.com" target="_blank">
            <i class="fab fa-twitter"></i>
                </a>
                <a href="https://github.com/edeoute1" target="_blank">
