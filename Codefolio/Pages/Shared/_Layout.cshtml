  </div><br />

  <div class="circular-progress java">
    <span class="value">Java</span>
  </div><br />

  <div class="circular-progress python">
    <span class="value">Python</span>
  </div><br />
  </div>

  <div class="stats">
  <div class="circular-progress R">
    <span class="value">R</span>
  </div><br />

  <div class="circular-progress chash">
    <span class="value">C#</span>
  </div><br />

  <div class="circular-progress pandas">
    <span class="value">Pandas</span>
  </div><br />
  </div>
  
